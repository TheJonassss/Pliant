},
{
automatic = 1;
code = "sub zero by zero.zero;\012";
name = zero;
},
{
automatic = 1;
code = "sub a by a.ss01;\012sub aacute by aacute.ss01;\012sub abreve by abreve.ss01;\012sub acaron by acaron.ss01;\012sub acircumflex by acircumflex.ss01;\012sub adieresis by adieresis.ss01;\012sub adotbelow by adotbelow.ss01;\012sub agrave by agrave.ss01;\012sub amacron by amacron.ss01;\012sub aogonek by aogonek.ss01;\012sub aring by aring.ss01;\012sub astroke by astroke.ss01;\012sub atilde by atilde.ss01;\012sub germandbls by germandbls.ss01;\012sub at by at.ss01;\012sub ampersand by ampersand.ss01;\012";
